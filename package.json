{
  "name": "@wabot-dev/template",
  "version": "1.0.0",
  "main": "./dist/run.js",
  "type": "module",
  "scripts": {
    "dev": "node --import=@yucacodes/ts --import=./env.mjs ./src/run.ts",
    "build": "tsc --noEmit && tsup-node ./src/run.ts --format esm --clean --no-splitting --sourcemap",
    "start": "node ./dist/run.js",
    "fmt": "prettier --write .",
    "tsc": "tsc --noEmit",
    "test:unit": "node --import=@yucacodes/ts  --test './src/**/*.unit.test.ts'"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@wabot-dev/framework": "^0.5.10"
  },
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "@types/ws": "^8.18.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1"
  },
  "overrides": {
    "minimatch": "^9.0.7",
    "picomatch": "^4.0.4",
    "qs": "^6.15.0",
    "rollup": "^4.60.0",
    "socket.io-parser": "^4.2.6"
  }
}
