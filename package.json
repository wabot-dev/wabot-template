{
  "name": "@wabot-dev/template",
  "version": "1.0.0",
  "main": "./dist/run.js",
  "type": "module",
  "scripts": {
    "dev": "node --import=@yucacodes/ts --env-file=./.env ./src/_run_.ts",
    "dev:watch": "node --import=@yucacodes/ts --env-file=./.env --watch --watch-preserve-output ./src/_run_.ts",
    "cmd": "node --import=@yucacodes/ts ./src/_cmd_.ts",
    "build": "node ./node_modules/@wabot-dev/framework/dist/build/build.js",
    "start": "WABOT_BUNDLED=1 node ./dist/entry.js",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "tsc": "tsc --noEmit",
    "test:unit": "node --import=@yucacodes/ts --env-file=./.env  --test './src/**/*.unit.test.ts'"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@wabot-dev/framework": "0.9.27"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "@swc/core": "^1.15.8",
    "@types/ws": "^8.18.1"
  }
}
