# debug important things
DEBUG=wabot:*:error,wabot:*:warn,wabot:*:info

# Postgres: leave empty for the in-memory store (state lands in .wabot/).
# Set it to persist data and to run multiple instances (tables auto-create).
# DATABASE_URL=postgres://user:pass@localhost:5432/wabot
DATABASE_URL=

# AI providers — uncomment and set a key to let your bot talk to a model.
# The framework rejects keys that are defined but empty, so leave the ones
# you are not using commented out.
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
